# Oracle Cloud VM에 복사 후 .env 로 저장
# cp .env.oracle.example .env && nano .env

# ---- 필수 ----
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-at-least-32-characters-long-secret
PUBLIC_DATA_API_KEY=your-data-go-kr-api-key
SITE_URL=http://YOUR_VM_PUBLIC_IP

# ---- 도메인 · HTTPS (setup-https.sh) ----
DOMAIN=bizgrant.kr
CERTBOT_EMAIL=admin@bizgrant.kr
# HTTPS 적용 후 SITE_URL=https://bizgrant.kr 로 자동 갱신됨
HTTPS_PORT=443

# ---- DB (기본값 그대로 사용 가능) ----
POSTGRES_DB=bizgrant
POSTGRES_USER=postgres

# ---- 웹 포트 (80 사용, 방화벽에서 80 열기) ----
HTTP_PORT=80

# ---- 뉴스레터 (가입자 생기기 전까지 SMTP 비워두면 발송만 실패, 사이트는 동작) ----
NEWSLETTER_ENABLED=true
NEWSLETTER_FROM=noreply@bizgrant.kr
MAIL_HOST=
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# ---- JVM (Always Free 6GB RAM VM 기준) ----
JAVA_OPTS=-Xms384m -Xmx1024m -XX:+UseG1GC

# ---- 동기화 (기본: 매일 새벽 3시 1회) ----
GRANT_SYNC_CRON=0 0 3 * * *

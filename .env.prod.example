# VPS에 복사 후 .env 로 저장
# cp .env.prod.example .env && nano .env

# ---- 필수 ----
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-at-least-32-characters-long-secret
PUBLIC_DATA_API_KEY=your-data-go-kr-api-key
SITE_URL=http://YOUR_VPS_PUBLIC_IP

# ---- 도메인 · HTTPS (setup-https.sh) ----
DOMAIN=bizgrant.kr
CERTBOT_EMAIL=admin@bizgrant.kr
HTTPS_PORT=443

# ---- DB ----
POSTGRES_DB=bizgrant
POSTGRES_USER=postgres

# ---- 웹 포트 ----
HTTP_PORT=80

# ---- 뉴스레터 (SMTP 비워두면 발송만 실패, 사이트는 동작) ----
NEWSLETTER_ENABLED=true
NEWSLETTER_FROM=noreply@bizgrant.kr
MAIL_HOST=
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# ---- 관리자 (최초 로그인, 생략 시 BizGrant2026!) ----
# ADMIN_PASSWORD=BizGrant2026!

# ---- JVM (Hostinger KVM 1: 4GB RAM 기준) ----
JAVA_OPTS=-Xms384m -Xmx1024m -XX:+UseG1GC

# ---- 동기화 (매일 새벽 3시) ----
GRANT_SYNC_CRON=0 0 3 * * *
